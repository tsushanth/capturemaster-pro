<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CaptureMasterPro" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.CaptureMasterPro.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#1A1A2E</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenAnimationDuration">300</item>
        <item name="postSplashScreenTheme">@style/Theme.CaptureMasterPro</item>
    </style>
</resources>
